{
  "name": "copilot-deck",
  "version": "0.1.0",
  "description": "Browser-based multi-session control panel for the GitHub Copilot CLI (ACP)",
  "keywords": ["copilot", "agent", "acp", "cli", "github-copilot"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liuneng1994/copilot-deck.git"
  },
  "homepage": "https://github.com/liuneng1994/copilot-deck#readme",
  "bugs": "https://github.com/liuneng1994/copilot-deck/issues",
  "type": "module",
  "bin": {
    "copilot-deck": "./bin/copilot-deck.mjs"
  },
  "engines": {
    "node": ">=22"
